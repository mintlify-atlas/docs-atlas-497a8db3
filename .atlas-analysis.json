  "keyFeatures": [
    "Dynamic command surface from Google Discovery Service",
    "OAuth2, Service Account, and headless authentication",
    "Structured JSON output for AI agents",
    "100+ agent skills for Drive, Gmail, Calendar, Sheets, Docs, Chat",
    "MCP server for Model Context Protocol clients",
    "Auto-pagination and multipart file uploads",
    "Schema introspection with gws schema command",
    "Model Armor integration for response sanitization",
    "Gemini CLI extension support"
  ],
  "publicApiSurface": [
    "gws drive files list",
    "gws gmail users messages list",
    "gws calendar events list",
    "gws sheets spreadsheets create",
    "gws docs documents create",
    "gws chat spaces messages create",
    "gws admin users list",
    "gws auth setup",
    "gws auth login",
    "gws schema <service.resource.method>",
    "gws mcp --services <list>",
    "gws drive-upload <file>",
    "gws gmail-send --to <email> --subject <text> --body <text>",
    "gws sheets-append --spreadsheet-id <id> --range <range> --values <json>",
    "gws calendar-insert --summary <text> --start <datetime> --end <datetime>",
    "gws chat-send --space <id> --text <message>"
  ]
